# PhotoToPoetry Backend Environment Template
# Copy this to .env and fill in your actual keys.

# --- Gemini API Keys ---
# Generate these from two different Google Accounts to bypass rate limits.
GEMINI_API_KEY=your_primary_key_here
GEMINI_API_KEY_SECONDARY=your_secondary_key_here

# --- Config (Optional) ---
GEMINI_MODEL=gemini-1.5-flash-lite
API_TIMEOUT=30
